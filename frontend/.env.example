# ── API URL ───────────────────────────────────────────────────────────────────
# Leave empty (or unset) for local development — Vite proxies /api calls to
# localhost:8000 automatically via vite.config.js.
# For production builds, set this to your Railway backend URL:
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=
