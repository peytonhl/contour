# ── API URL ───────────────────────────────────────────────────────────────────
# Leave empty (or unset) for local development — Vite proxies /api calls to
# localhost:8000 automatically via vite.config.js.
# For production builds, set this to your Railway backend URL:
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=

# ── PostHog analytics ────────────────────────────────────────────────────────
# Create a project at https://posthog.com and grab the "Project API key" from
# Settings → Project. Leave unset locally — analytics will silently no-op until
# the key is configured (typically in Vercel env vars for prod).
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog API host — only override if you use the EU instance.
# Default: https://us.i.posthog.com
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
