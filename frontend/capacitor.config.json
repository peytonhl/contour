{
  "appId": "com.peytonhl.contour",
  "appName": "Contour",
  "webDir": "dist",
  "server": {
    "url": "https://contour-rosy.vercel.app",
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": false
  },
  "ios": {
    "contentInset": "never",
    "scrollEnabled": true,
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#08080a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#08080a"
    }
  }
}
