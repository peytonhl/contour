# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
.pytest_cache/

# Environment
.env
.env.local
# .env.production is committed (public values only — see frontend/.env.production).
# Per-machine secret overrides (PostHog key, Apple sign-in IDs, etc.) go in
# .env.production.local — gitignored so secrets never get committed.
.env.production.local
.env.*.local

# SQLite
*.db
*.sqlite

# Node
node_modules/
dist/
.vite/

# Capacitor — keep ios/ and android/ in git, exclude their build artifacts
frontend/ios/App/Pods/
frontend/ios/.xcode.env.local
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
