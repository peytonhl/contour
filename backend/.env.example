# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# Enable the "Google+ API" (or "Google Identity"), then create OAuth 2.0
# credentials (Web Application type).
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Where Google redirects after login. Must be added to "Authorized redirect URIs"
# in the Google Cloud Console for your OAuth client.
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Production (uncomment and set):
# GOOGLE_REDIRECT_URI=https://your-backend.railway.app/auth/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
# Any long random string. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit the real value.
JWT_SECRET=replace_with_a_long_random_secret
# Optional — how many days a session token stays valid (default: 30)
# JWT_EXPIRE_DAYS=30

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used in the OAuth redirect after login so the backend can send the token to
# the correct frontend origin.
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production (uncomment and set):
# FRONTEND_URL=https://contour-rosy.vercel.app

# ── Spotify API ───────────────────────────────────────────────────────────────
# Used for music metadata (album art, artist info, search, tracklists).
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── Sign in with Apple (optional) ─────────────────────────────────────────────
# Required for iOS App Store: if Google sign-in is offered, Sign in with Apple
# must also be offered. Get a Services ID from the Apple Developer portal:
# Certificates, Identifiers & Profiles → Identifiers → "+" → Services IDs.
# When unset, the /auth/apple endpoint returns 503 and the frontend hides the
# Apple sign-in button automatically. Set both backend and the frontend var
# (VITE_APPLE_CLIENT_ID) to enable.
# APPLE_CLIENT_ID=com.peytonhl.contour.signin

# ── Apple Music (optional, catalog-only deep links) ──────────────────────────
# Used to resolve Spotify albums/tracks → Apple Music IDs so the frontend can
# show a "Play on Apple Music" deep link. Catalog-only; no user auth.
#
# Create a MusicKit identifier in the Apple Developer portal under Keys, then
# generate an ES256 signing key (download the .p8 file). The private key value
# below is the *contents* of the .p8 file (PEM-encoded). Newlines in env vars
# can be encoded as literal \n — the service decodes them.
#
# When any of these three is unset, /apple-music/match/* returns 404 and the
# "Play on Apple Music" button hides itself.
# APPLE_MUSIC_TEAM_ID=ABCDE12345
# APPLE_MUSIC_KEY_ID=ABCDE12345
# APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGTAg...\n-----END PRIVATE KEY-----"

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use SQLite locally (zero setup — file created automatically).
# For production, Railway sets this automatically when you add a Postgres plugin.
# If you need to set it manually:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
