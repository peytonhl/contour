# Environment variables are split by service:
#
#   backend/.env.example   — FastAPI server (Google OAuth, JWT, Spotify API, DB)
#   frontend/.env.example  — Vite / React (backend URL for production builds)
#
# Copy each to the same directory without the .example suffix:
#   cp backend/.env.example  backend/.env
#   cp frontend/.env.example frontend/.env
